# ─────────────────────────────────────────────────────────────────────────────
# Claude Code — Linux Fork — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The launcher (claude-code.sh) loads this file automatically.
#
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic API (required for direct access) ────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── LiteLLM Proxy (optional) ─────────────────────────────────────────────────
# Set this if you're routing through a LiteLLM proxy instead of Anthropic directly.
# Start the proxy with: ./litellm/start.sh
# Then uncomment:
# ANTHROPIC_BASE_URL=http://localhost:4000

# ── Model selection (optional) ───────────────────────────────────────────────
# Override the default model used by Claude Code.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_SMALL_FAST_MODEL=claude-3-5-haiku-20241022

# ── AWS Bedrock (optional, mutually exclusive with above) ────────────────────
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1

# ── Google Vertex AI (optional, mutually exclusive with above) ───────────────
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=us-east5

# ── Azure Foundry (optional, mutually exclusive with above) ──────────────────
# CLAUDE_CODE_USE_FOUNDRY=1
# ANTHROPIC_FOUNDRY_RESOURCE=your-azure-resource

# ── Proxy / Network (optional) ───────────────────────────────────────────────
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ── Debug (optional) ─────────────────────────────────────────────────────────
# CLAUDE_CODE_DEBUG=1
# ANTHROPIC_LOG=debug
